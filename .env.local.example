# Gmail / Google Workspace SMTP
# GMAIL_USER     = adres email konta Google Workspace, np. contact@sprintpmc.com
# GMAIL_APP_PASSWORD = 16-znakowe hasło aplikacji z Google Account
#
# Jak wygenerować App Password:
# 1. Zaloguj się na konto Google (contact@sprintpmc.com)
# 2. Wejdź: myaccount.google.com → Bezpieczeństwo → Weryfikacja dwuetapowa (włącz)
# 3. Wróć do Bezpieczeństwo → Hasła do aplikacji
# 4. Wybierz "Inna (własna nazwa)" → wpisz "SprintPMC Website" → Generuj
# 5. Skopiuj wygenerowane 16 znaków (bez spacji)
#
# Na Vercel dodaj w: Settings → Environment Variables

GMAIL_USER=contact@sprintpmc.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
